# ==============================================
# 環境變數範本檔
# 使用方法：把這個檔案複製一份，命名為 .env，再填入實際的值
# 注意：.env 裡面有機密資訊，千萬不要 commit 到 GitHub！
# ==============================================

# ─────────────────────────────────────
# 前端
# ─────────────────────────────────────

# 前端對外的完整網址
FRONTEND_URL=http://localhost:3000

# 前端 dev 階段呼叫的後端 URL（給 vite proxy 用，spec-10 §5.1）
VITE_DEV_BACKEND_URL=http://localhost:8000

# 注意：
# - P1 起前端不再直接持有後端網址。所有 API 呼叫一律走相對路徑 /api/*
#   ・dev 階段由 vite.config.js 的 proxy 轉到後端
#   ・prod 階段由 nginx.conf 的 location /api/ proxy_pass 轉到後端
# - VITE_BACKEND_URL（既有變數）在 P1 之後保留為相容，無實際用途
VITE_BACKEND_URL=http://localhost:8000

# ─────────────────────────────────────
# 後端：資料庫
# ─────────────────────────────────────
POSTGRES_DB=scilens
POSTGRES_USER=scilens
POSTGRES_PASSWORD=scilens

# 後端用的完整 DSN（asyncpg）
# 本地開發直連 postgres 時用 localhost；docker compose 用 service 名 postgres
DATABASE_URL=postgresql+asyncpg://scilens:scilens@localhost:5432/scilens

# ─────────────────────────────────────
# 後端：認證 (spec-13)
# ─────────────────────────────────────
# JWT 簽章金鑰（prod 請改成隨機 32+ 字元字串）
JWT_SECRET=dev-secret-change-me-in-production-please-32chars
JWT_EXPIRES_HOURS=24
COOKIE_SECURE=false       # prod 用 true（要 HTTPS）
COOKIE_SAMESITE=lax       # prod 用 strict

# 後端 CORS 允許 origin（dev 階段需放前端 dev server）
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────
# LLM (P2 才會用到)
# ─────────────────────────────────────
# ⚠️ P2 起前端 src/llm/ 改為呼叫後端 /api/llm/*，不再直接呼叫 vLLM。
# 故下列變數只放在「後端」（不加 VITE_ 前綴），瀏覽器無法看到。

# vLLM (OpenAI 相容)
VLLM_BASE_URL=https://vllm-193.hsueh.tw/v1
VLLM_MODEL_NAME=/models/gemma-4-26B-A4B-it
VLLM_API_KEY=dummy

# 預設生成參數
LLM_DEFAULT_TEMPERATURE=0.7
LLM_DEFAULT_MAX_TOKENS=1024

# ─────────────────────────────────────
# RAGFlow (P2 起 N6；P3 起 N1/N2)
# ─────────────────────────────────────
# 用於教師端的「文獻引用 / 出題輔助 / 班級摘要」(workflow.md §7 N1/N2/N6)

# Mock 模式：true 時後端回傳預錄假資料，不打真實 RAGFlow（demo 階段方便先看效果）。
# 真實 RAGFlow 部署完成後改 false 並填好下方三個 RAGFLOW_* 變數即可切換。
RAGFLOW_MOCK=true

RAGFLOW_ENDPOINT=https://ragflow-thesisflow.hsueh.tw
RAGFLOW_AGENT_ID=5f5cc79e3afb11f1b0be26501d5adb82
RAGFLOW_API_KEY=ragflow-your-api-key-here

# ─────────────────────────────────────
# 既有：前端 LLM provider 設定（P2 之前仍生效）
# ─────────────────────────────────────
# P2 之後可從 .env 移除（前端不再直連 LLM）
VITE_LLM_PROVIDER=vllm
VITE_VLLM_BASE_URL=https://vllm-193.hsueh.tw/v1
VITE_VLLM_MODEL_NAME=/models/gemma-4-26B-A4B-it
VITE_VLLM_API_KEY=dummy
VITE_LLM_DEFAULT_TEMPERATURE=0.7
VITE_LLM_DEFAULT_MAX_TOKENS=1024
