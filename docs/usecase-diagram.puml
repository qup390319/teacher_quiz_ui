@startuml SciLens_UseCase_Diagram
' ============================================================
' SciLens — 自然科學迷思概念診斷系統 Use Case Diagram
' 角色：教師、學生
' 說明：本圖使用一般大眾可理解的措辭，不含技術名詞與資料庫欄位名稱
' ============================================================

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecaseBackgroundColor #FFFDE7
skinparam usecaseBorderColor #8B5E3C
skinparam packageBorderColor #C19A6B
skinparam packageBackgroundColor #FFF8E7
skinparam arrowColor #5A3E22
skinparam actorBorderColor #5A3E22

' ---------- 角色 ----------
actor "教師" as Teacher #F0B962
actor "學生" as Student #5DADE2

' ========== 共用：登入 ==========
package "登入與登出" as AuthPkg {
  usecase "登入系統" as UC_A1
  usecase "登出系統" as UC_A2
}

Teacher --> UC_A1
Teacher --> UC_A2
Student --> UC_A1
Student --> UC_A2

' ========== 教師：出題 ==========
package "出題與題目管理" as QuizPkg {
  usecase "瀏覽題組清單" as UC_T1
  usecase "建立新的測驗題組" as UC_T2
  usecase "挑選想評量的\n學習概念" as UC_T3
  usecase "編輯題目內容" as UC_T4
  usecase "暫存草稿" as UC_T5
  usecase "正式發布題組" as UC_T6
  usecase "修改已建立的題組" as UC_T7
  usecase "複製題組另存新檔" as UC_T8
  usecase "刪除草稿" as UC_T9
  usecase "從題目庫挑選現成題目" as UC_T10
  usecase "自動依概念順序\n整理題目" as UC_T11
  usecase "預覽學生看到的畫面" as UC_T12
  usecase "請 AI 幫忙\n潤飾題目文字" as UC_T13
  usecase "請 AI 幫忙\n建議答案選項" as UC_T14
  usecase "請 AI 幫忙\n設計易混淆的錯誤選項" as UC_T15
}

Teacher --> UC_T1
Teacher --> UC_T2
Teacher --> UC_T7
Teacher --> UC_T8
Teacher --> UC_T9

UC_T2 ..> UC_T3 : <<include>>
UC_T2 ..> UC_T4 : <<include>>
UC_T4 ..> UC_T5 : <<include>>
UC_T4 ..> UC_T6 : <<include>>
UC_T4 ..> UC_T10 : <<extend>>
UC_T4 ..> UC_T11 : <<extend>>
UC_T4 ..> UC_T12 : <<extend>>
UC_T4 ..> UC_T13 : <<extend>>
UC_T4 ..> UC_T14 : <<extend>>
UC_T4 ..> UC_T15 : <<extend>>

' ========== 教師：派題 ==========
package "派發測驗給學生" as AssignPkg {
  usecase "把測驗派給整個班級" as UC_D1
  usecase "設定這次是\n第一次測驗或複習" as UC_D2
  usecase "修改已派發的測驗" as UC_D3
  usecase "取消已派發的測驗" as UC_D4
  usecase "把補救練習\n指派給特定學生" as UC_D5
  usecase "挑選要補救的學生" as UC_D6
  usecase "調整補救對象名單" as UC_D7
}

Teacher --> UC_D1
Teacher --> UC_D3
Teacher --> UC_D4
Teacher --> UC_D5

UC_D1 ..> UC_D2 : <<include>>
UC_D5 ..> UC_D6 : <<include>>
UC_D5 ..> UC_D7 : <<extend>>

' ========== 教師：查看結果 ==========
package "查看學生學習狀況" as DashPkg {
  usecase "查看所有班級總覽" as UC_R1
  usecase "查看單一班級的\n學習狀況" as UC_R2
  usecase "比較不同班級\n在同一概念的表現" as UC_R3
  usecase "查看全校最常出現的\n錯誤想法排行" as UC_R4
  usecase "查看單一班級的\n詳細報告" as UC_R5
  usecase "查看 AI 與學生\n的對話紀錄" as UC_R6
  usecase "查看補救練習\n是否有效果" as UC_R7
  usecase "切換要看的\n測驗題組" as UC_R8
}

Teacher --> UC_R1
Teacher --> UC_R2
Teacher --> UC_R3
Teacher --> UC_R4
Teacher --> UC_R5
Teacher --> UC_R7

UC_R5 ..> UC_R6 : <<extend>>
UC_R1 ..> UC_R8 : <<include>>

' ========== 教師：班級管理 ==========
package "班級與學生管理" as ClassPkg {
  usecase "瀏覽班級列表" as UC_C1
  usecase "查看班級名單" as UC_C2
  usecase "新增學生" as UC_C3
  usecase "移除學生" as UC_C4
}

Teacher --> UC_C1
Teacher --> UC_C2
UC_C2 ..> UC_C3 : <<extend>>
UC_C2 ..> UC_C4 : <<extend>>

' ========== 教師：知識地圖 ==========
package "課程概念與常見錯誤想法" as KnowPkg {
  usecase "查看課程包含\n哪些學習概念" as UC_K1
  usecase "查看概念之間的\n先後學習順序" as UC_K2
  usecase "新增或刪除\n自訂的錯誤想法" as UC_K3
  usecase "查看學生常見\n錯誤想法的成因說明" as UC_K4
}

Teacher --> UC_K1
Teacher --> UC_K3
Teacher --> UC_K4
UC_K1 ..> UC_K2 : <<include>>

' ========== 教師：補救練習 ==========
package "補救練習設計" as TreatPkg {
  usecase "瀏覽補救練習\n題組清單" as UC_H1
  usecase "建立新的補救練習" as UC_H2
  usecase "修改補救練習內容" as UC_H3
  usecase "查看補救練習\n對話紀錄" as UC_H4
}

Teacher --> UC_H1
Teacher --> UC_H2
Teacher --> UC_H3
Teacher --> UC_H4

' ========== 學生 ==========
package "學生使用區" as StuPkg {
  usecase "查看老師指派的任務" as UC_S1
  usecase "進行測驗" as UC_S2
  usecase "逐題作答\n（先答完全部再看結果）" as UC_S3
  usecase "和 AI 對話\n釐清自己的想法" as UC_S4
  usecase "查看自己的\n學習成果報告" as UC_S5
  usecase "進行補救練習對話" as UC_S6
  usecase "調整畫面字體大小" as UC_S7
}

Student --> UC_S1
Student --> UC_S2
Student --> UC_S5
Student --> UC_S6
Student --> UC_S7

UC_S2 ..> UC_S3 : <<include>>
UC_S2 ..> UC_S4 : <<include>>

' ========== 補充說明 ==========
note right of QuizPkg
  教師在編輯題目時，可隨時請 AI
  幫忙潤飾文字、建議答案，或產生
  學生容易選錯的干擾選項。
end note

note right of StuPkg
  測驗流程：
  看說明 → 逐題作答 → 與 AI 對話
  → 完成測驗 → 查看個人報告

  補救練習流程：
  看情境 → 與 AI 對話 → 看結果
  → 反思自己的想法
end note

note bottom of AssignPkg
  測驗題組：派給整個班級
  補救練習：依個別學生需求派發
end note

@enduml
